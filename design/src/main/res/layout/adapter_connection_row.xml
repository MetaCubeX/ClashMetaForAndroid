<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/AppCard.Filled"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainer"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:id="@+id/conn_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/conn_app_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_m3_status_chip_neutral"
                android:contentDescription="@string/connections_app_icon"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_baseline_dns"
                tools:src="@mipmap/ic_launcher" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/conn_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.App.TitleSmall"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    tools:text="example.com" />

                <TextView
                    android:id="@+id/conn_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="Chrome · tcp" />
            </LinearLayout>

            <TextView
                android:id="@+id/conn_network_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_m3_status_chip_neutral"
                android:paddingHorizontal="9dp"
                android:paddingVertical="4dp"
                android:textAppearance="@style/TextAppearance.App.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="TCP" />

            <ImageView
                android:id="@+id/conn_expand"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/connections_details"
                android:padding="8dp"
                android:src="@drawable/ic_baseline_expand_more"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/conn_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/connections_close"
                android:padding="11dp"
                android:src="@drawable/ic_baseline_close"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <TextView
            android:id="@+id/conn_route"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.App.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="Chain: selector › node" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/conn_meta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.App.LabelMedium"
                android:textColor="?attr/colorOnSurface"
                tools:text="↑1 KiB · ↓2 KiB · RULE" />

            <TextView
                android:id="@+id/conn_rule_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_m3_status_chip_neutral"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="9dp"
                android:paddingVertical="4dp"
                android:textAppearance="@style/TextAppearance.App.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="MATCH" />
        </LinearLayout>

        <TextView
            android:id="@+id/conn_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAppearance="@style/TextAppearance.App.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:text="Details"
            tools:visibility="visible" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
