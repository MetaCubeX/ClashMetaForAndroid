<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_announcement_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_baseline_campaign"
            app:tint="?attr/colorPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/announcement_sheet_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <TextView
        android:id="@+id/announcement_sheet_source"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="36dp"
        android:background="@drawable/bg_announcement_sheet_source_pill"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="From VPN Demo" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/announcement_sheet_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.15"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="?attr/colorOnSurface"
            android:textIsSelectable="true"
            tools:text="Full announcement body. Any length here, sheet scrolls naturally if it overflows." />
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/announcement_sheet_open_link"
            style="@style/AppButton.Tonal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/sub_announcement_open_link"
            android:textAllCaps="false"
            android:visibility="gone"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_baseline_language"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/announcement_sheet_support"
            style="@style/AppButton.Tonal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/sub_announcement_support"
            android:textAllCaps="false"
            android:visibility="gone"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_baseline_headset_mic"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/announcement_sheet_copy"
            style="@style/AppButton.Text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/announcement_action_copy"
            android:textAllCaps="false"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_baseline_content_copy"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="18dp" />
    </LinearLayout>
</LinearLayout>
