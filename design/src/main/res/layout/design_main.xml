<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="self"
            type="com.github.kr328.clash.design.MainDesign" />
        <variable
            name="clashRunning"
            type="boolean" />
        <variable
            name="tunnelStarting"
            type="boolean" />
        <variable
            name="forwarded"
            type="String" />
        <variable
            name="mode"
            type="String" />
        <variable
            name="profileName"
            type="String" />
        <variable
            name="modeActiveColor"
            type="int" />
        <variable
            name="modeInactiveColor"
            type="int" />
        <variable
            name="isRuleMode"
            type="boolean" />
        <variable
            name="isGlobalMode"
            type="boolean" />
        <variable
            name="isDirectMode"
            type="boolean" />
        <variable
            name="hasProfiles"
            type="boolean" />

        <import type="android.view.View" />
        <import type="com.github.kr328.clash.design.MainDesign.Request" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/mainDashboardBackground"
        android:paddingStart="@{self.surface.insets.start}"
        android:paddingEnd="@{self.surface.insets.end}">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="@{self.surface.insets.top}"
            android:paddingBottom="@{self.surface.insets.bottom}">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/toolbar_height"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/main_toolbar_padding_horizontal">

                <ImageButton
                    android:layout_width="@dimen/large_item_header_layout_size"
                    android:layout_height="@dimen/large_item_header_layout_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings"
                    android:onClick="@{() -> self.request(Request.OpenSettings)}"
                    android:padding="@dimen/toolbar_image_action_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_neon_toolbar_settings" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/btn_theme_toggle"
                    android:layout_width="@dimen/toolbar_theme_button_size"
                    android:layout_height="@dimen/toolbar_theme_button_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/theme_toggle"
                    android:focusable="true"
                    android:gravity="center"
                    android:onClick="@{() -> self.request(Request.CycleTheme)}"
                    android:text="@string/main_emoji_moon"
                    android:textColor="?attr/colorControlNormal"
                    android:textSize="22sp" />

                <ImageButton
                    android:layout_width="@dimen/large_item_header_layout_size"
                    android:layout_height="@dimen/large_item_header_layout_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/add"
                    android:onClick="@{() -> self.request(Request.OpenNewProfile)}"
                    android:padding="@dimen/toolbar_image_action_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_neon_toolbar_add" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <View
                    android:id="@+id/main_power_glow"
                    android:layout_width="@dimen/main_power_glow_size"
                    android:layout_height="@dimen/main_power_glow_size"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:background="@drawable/bg_power_glow" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/main_power_card"
                    android:layout_width="@dimen/main_power_button_size"
                    android:layout_height="@dimen/main_power_button_size"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:onClick="@{() -> self.request(Request.ToggleStatus)}"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/main_power_button_radius"
                    app:cardElevation="0dp"
                    app:cardMaxElevation="0dp"
                    app:cardUseCompatPadding="false"
                    app:rippleColor="@color/tech_secondary_soft"
                    app:strokeColor="@android:color/transparent">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/main_power_icon_base"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:contentDescription="@string/tap_to_start"
                            android:src="@drawable/ic_clash"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:id="@+id/main_power_icon_overlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:alpha="0"
                            android:contentDescription="@string/tap_to_start"
                            android:scaleType="fitCenter"
                            android:visibility="gone" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="@dimen/main_padding_horizontal"
                android:paddingBottom="4dp"
                android:text="@{clashRunning ? @string/format_traffic_forwarded(forwarded) : @string/tap_to_start}"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                android:textColor="?attr/colorMainDashboardText"
                tools:text="12 MB Forwarded" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.85"
                android:gravity="center"
                android:paddingBottom="8dp"
                android:text="@{profileName != null ? @string/format_profile_activated(profileName) : @string/not_selected}"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="?attr/colorMainDashboardText"
                tools:text="Profile X" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/main_padding_horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:text="@string/mode"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle2"
                android:textColor="?attr/colorMainDashboardText"
                android:visibility="@{clashRunning ? View.VISIBLE : View.GONE}" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/main_padding_horizontal"
                android:visibility="@{clashRunning ? View.VISIBLE : View.GONE}"
                android:weightSum="3">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:onClick="@{() -> self.request(Request.PatchModeRule)}"
                    app:cardBackgroundColor="@{isRuleMode ? modeActiveColor : modeInactiveColor}"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardStrokeWidthBound="@{isRuleMode ? @dimen/stroke_neon : @dimen/stroke_hairline}"
                    app:strokeColor="@color/tech_primary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/mode_chip_rule"
                            android:text="@string/mode_emoji_rule"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/mode_chip_rule"
                            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                            android:textColor="?attr/colorMainDashboardText"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:onClick="@{() -> self.request(Request.PatchModeGlobal)}"
                    app:cardBackgroundColor="@{isGlobalMode ? modeActiveColor : modeInactiveColor}"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardStrokeWidthBound="@{isGlobalMode ? @dimen/stroke_neon : @dimen/stroke_hairline}"
                    app:strokeColor="@color/tech_primary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/mode_chip_global"
                            android:text="@string/mode_emoji_global"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/mode_chip_global"
                            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                            android:textColor="?attr/colorMainDashboardText"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:onClick="@{() -> self.request(Request.PatchModeDirect)}"
                    app:cardBackgroundColor="@{isDirectMode ? modeActiveColor : modeInactiveColor}"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardStrokeWidthBound="@{isDirectMode ? @dimen/stroke_neon : @dimen/stroke_hairline}"
                    app:strokeColor="@color/tech_primary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/mode_chip_direct"
                            android:text="@string/mode_emoji_direct"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/mode_chip_direct"
                            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                            android:textColor="?attr/colorMainDashboardText"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="120dp"
                android:paddingBottom="8dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/profile_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true"
                    android:clipToPadding="true"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="never"
                    android:visibility="@{hasProfiles ? View.VISIBLE : View.GONE}"
                    tools:listitem="@layout/adapter_profile" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/main_empty_profiles_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="@dimen/main_padding_horizontal"
                    android:visibility="@{hasProfiles ? View.GONE : View.VISIBLE}"
                    app:cardBackgroundColor="@color/main_card_glass"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/tech_secondary_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/main_no_profiles_title"
                            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                            android:textColor="?attr/colorMainDashboardText"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:alpha="0.86"
                            android:text="@string/main_no_profiles_subtitle"
                            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                            android:textColor="?attr/colorMainDashboardText" />

                        <com.google.android.material.button.MaterialButton
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:onClick="@{() -> self.request(Request.OpenNewProfile)}"
                            android:text="@string/main_add_subscription"
                            app:icon="@drawable/ic_neon_toolbar_add"
                            app:iconGravity="textStart"
                            app:iconPadding="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="2dp"
                android:paddingTop="10dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="2"
                    android:onClick="@{() -> self.request(Request.OpenProfiles)}"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="8dp"
                    android:text="@string/profiles"
                    android:textAlignment="center"
                    android:textColor="?attr/colorMainDashboardText"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="2"
                    android:onClick="@{() -> self.request(Request.OpenConnections)}"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="8dp"
                    android:text="@string/connections_title"
                    android:textAlignment="center"
                    android:textColor="?attr/colorMainDashboardText"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="2"
                    android:onClick="@{() -> self.request(Request.OpenRules)}"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="8dp"
                    android:text="@string/rules"
                    android:textAlignment="center"
                    android:textColor="?attr/colorMainDashboardText"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="2"
                    android:onClick="@{() -> self.request(Request.OpenEffectiveRules)}"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="8dp"
                    android:text="@string/routing_rules"
                    android:textAlignment="center"
                    android:textColor="?attr/colorMainDashboardText"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="2"
                    android:onClick="@{() -> self.request(Request.OpenAbout)}"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="8dp"
                    android:text="@string/about"
                    android:textAlignment="center"
                    android:textColor="?attr/colorMainDashboardText"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
