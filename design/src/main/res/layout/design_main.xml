<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="self"
            type="com.github.kr328.clash.design.MainDesign" />
        <variable
            name="clashRunning"
            type="boolean" />
        <variable
            name="tunnelStarting"
            type="boolean" />
        <variable
            name="forwarded"
            type="String" />
        <variable
            name="mode"
            type="String" />
        <variable
            name="profileName"
            type="String" />
        <variable
            name="hasProfiles"
            type="boolean" />

        <import type="android.view.View" />
        <import type="com.github.kr328.clash.design.MainDesign.Request" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/mainDashboardBackground"
        android:paddingStart="@{self.surface.insets.start}"
        android:paddingEnd="@{self.surface.insets.end}">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="@{self.surface.insets.top}"
            android:paddingBottom="@{self.surface.insets.bottom}">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/toolbar_height"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/main_toolbar_padding_horizontal">

                <ImageButton
                    android:layout_width="@dimen/large_item_header_layout_size"
                    android:layout_height="@dimen/large_item_header_layout_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings"
                    android:onClick="@{() -> self.request(Request.OpenSettings)}"
                    android:padding="@dimen/toolbar_image_action_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_baseline_settings"
                    app:tint="?attr/colorOnSurface" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/btn_theme_toggle"
                    android:layout_width="@dimen/toolbar_theme_button_size"
                    android:layout_height="@dimen/toolbar_theme_button_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/theme_toggle"
                    android:focusable="true"
                    android:gravity="center"
                    android:onClick="@{() -> self.request(Request.CycleTheme)}"
                    android:text="@string/main_emoji_moon"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="22sp" />

                <ImageButton
                    android:layout_width="@dimen/large_item_header_layout_size"
                    android:layout_height="@dimen/large_item_header_layout_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/add"
                    android:onClick="@{() -> self.request(Request.OpenNewProfile)}"
                    android:padding="@dimen/toolbar_image_action_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_baseline_add"
                    app:tint="?attr/colorOnSurface" />

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp">

                <View
                    android:id="@+id/main_power_glow"
                    android:layout_width="@dimen/main_power_glow_size"
                    android:layout_height="@dimen/main_power_glow_size"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:background="@drawable/bg_power_glow" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/main_power_card"
                    style="@style/AppCard.Filled"
                    android:layout_width="@dimen/main_power_button_size"
                    android:layout_height="@dimen/main_power_button_size"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:focusable="false"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/main_power_button_radius"
                    app:cardElevation="0dp"
                    app:cardMaxElevation="0dp"
                    app:cardUseCompatPadding="false"
                    app:rippleColor="?attr/colorControlHighlight"
                    app:strokeColor="@android:color/transparent"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/main_power_icon_base"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:contentDescription="@string/tap_to_start"
                            android:src="@drawable/ic_clash"
                            android:scaleType="centerInside"
                            android:padding="@dimen/main_power_icon_padding" />

                        <ImageView
                            android:id="@+id/main_power_icon_overlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:alpha="0"
                            android:contentDescription="@string/tap_to_start"
                            android:scaleType="centerInside"
                            android:padding="@dimen/main_power_icon_padding"
                            android:visibility="gone" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="@dimen/main_padding_horizontal"
                android:paddingBottom="2dp"
                android:text="@{clashRunning ? @string/format_traffic_forwarded(forwarded) : @string/main_vpn_ready}"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="?attr/colorMainDashboardText"
                tools:text="12 MB Forwarded" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/main_padding_horizontal"
                android:paddingTop="2dp"
                android:paddingBottom="4dp"
                android:text="@string/mode"
                android:textAppearance="@style/TextAppearance.App.TitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginHorizontal="@dimen/main_padding_horizontal"
                android:layout_marginBottom="@dimen/main_mode_row_margin_bottom"
                android:background="@drawable/bg_m3_segment_container"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="2dp"
                android:visibility="visible">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/mode_toggle_group"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_rule"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:onClick="@{() -> self.request(Request.PatchModeRule)}"
                        android:paddingHorizontal="10dp"
                        android:text="@string/mode_chip_rule"
                        android:textAppearance="@style/TextAppearance.App.LabelMedium"
                        android:textColor="@color/selector_mode_button_text"
                        app:backgroundTint="@color/selector_mode_button_bg"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_mode_rule"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:iconSize="17dp"
                        app:iconTint="@color/selector_mode_button_text"
                        app:strokeColor="@color/selector_mode_button_stroke"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_global"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:onClick="@{() -> self.request(Request.PatchModeGlobal)}"
                        android:paddingHorizontal="10dp"
                        android:text="@string/mode_chip_global"
                        android:textAppearance="@style/TextAppearance.App.LabelMedium"
                        android:textColor="@color/selector_mode_button_text"
                        app:backgroundTint="@color/selector_mode_button_bg"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_mode_global"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:iconSize="17dp"
                        app:iconTint="@color/selector_mode_button_text"
                        app:strokeColor="@color/selector_mode_button_stroke"
                        app:strokeWidth="1dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/main_announcement_card"
                style="@style/AppCard.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/main_padding_horizontal"
                android:layout_marginBottom="6dp"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="10dp">

                    <!-- Header row: refresh + dismiss -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/announcement_text"
                            android:src="@drawable/ic_baseline_campaign"
                            app:tint="?attr/colorMainDashboardText" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:alpha="0.85"
                            android:text="@string/announcement_text"
                            android:textAppearance="@style/TextAppearance.App.BodySmall"
                            android:textColor="?attr/colorMainDashboardText" />

                        <ImageButton
                            android:id="@+id/main_announcement_refresh"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/sub_announcement_refresh"
                            android:src="@drawable/ic_baseline_sync"
                            app:tint="?attr/colorMainDashboardText" />

                        <ImageButton
                            android:id="@+id/main_announcement_dismiss"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/dismiss"
                            android:src="@drawable/ic_baseline_close"
                            app:tint="?attr/colorMainDashboardText" />
                    </LinearLayout>

                    <!-- "If unavailable, tap [icon]" hint row -->
                    <LinearLayout
                        android:id="@+id/main_announcement_unavailable_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:alpha="0.78"
                            android:text="@string/sub_announcement_if_unavailable"
                            android:textAppearance="@style/TextAppearance.App.BodyMedium"
                            android:textColor="?attr/colorMainDashboardText" />

                        <ImageButton
                            android:id="@+id/main_announcement_open_link"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="6dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/sub_announcement_open_link"
                            android:src="@drawable/ic_baseline_update"
                            app:tint="?attr/colorMainDashboardText" />
                    </LinearLayout>

                    <!-- Optional announcement message -->
                    <TextView
                        android:id="@+id/main_announcement_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="?attr/colorMainDashboardText"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="Announcement message" />

                    <!-- Stats grid: traffic | days | expires -->
                    <LinearLayout
                        android:id="@+id/main_announcement_stats_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.7"
                                android:text="@string/sub_announcement_traffic_left"
                                android:textAppearance="@style/TextAppearance.App.BodySmall"
                                android:textColor="?attr/colorMainDashboardText" />

                            <TextView
                                android:id="@+id/main_announcement_traffic_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/sub_announcement_unlimited"
                                android:textAppearance="@style/TextAppearance.App.TitleSmall"
                                android:textColor="?attr/colorMainDashboardText"
                                android:textStyle="bold"
                                tools:text="12.4 / 50 GB" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:layout_marginVertical="4dp"
                            android:alpha="0.2"
                            android:background="?attr/colorMainDashboardText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.7"
                                android:text="@string/sub_announcement_days_left"
                                android:textAppearance="@style/TextAppearance.App.BodySmall"
                                android:textColor="?attr/colorMainDashboardText" />

                            <TextView
                                android:id="@+id/main_announcement_days_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/sub_announcement_unlimited"
                                android:textAppearance="@style/TextAppearance.App.TitleSmall"
                                android:textColor="?attr/colorMainDashboardText"
                                android:textStyle="bold"
                                tools:text="28" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:layout_marginVertical="4dp"
                            android:alpha="0.2"
                            android:background="?attr/colorMainDashboardText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.7"
                                android:text="@string/sub_announcement_expires"
                                android:textAppearance="@style/TextAppearance.App.BodySmall"
                                android:textColor="?attr/colorMainDashboardText" />

                            <TextView
                                android:id="@+id/main_announcement_expires_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/sub_announcement_never"
                                android:textAppearance="@style/TextAppearance.App.TitleSmall"
                                android:textColor="?attr/colorMainDashboardText"
                                android:textStyle="bold"
                                tools:text="Apr 30" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Usage progress bar -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/main_announcement_usage_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:visibility="gone"
                        app:trackCornerRadius="3dp"
                        app:trackThickness="4dp" />

                    <!-- Legacy usage text (hidden by default, kept for compat) -->
                    <TextView
                        android:id="@+id/main_announcement_usage_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:alpha="0.7"
                        android:gravity="center"
                        android:textColor="?attr/colorMainDashboardText"
                        android:textSize="11sp"
                        android:visibility="gone"
                        tools:text="12.4 GB / 50 GB · expires Apr 30" />

                    <!-- Support button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/main_announcement_support"
                        style="@style/AppButton.Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/sub_announcement_support"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_baseline_info"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="96dp"
                android:paddingBottom="4dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/profile_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="never"
                    android:paddingBottom="76dp"
                    android:visibility="@{hasProfiles ? View.VISIBLE : View.GONE}"
                    tools:listitem="@layout/adapter_profile" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/main_empty_profiles_card"
                    style="@style/AppCard.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="@dimen/main_padding_horizontal"
                    android:visibility="@{hasProfiles ? View.GONE : View.VISIBLE}"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/main_no_profiles_title"
                            android:textAppearance="@style/TextAppearance.App.TitleMedium"
                            android:textColor="?attr/colorMainDashboardText"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:alpha="0.86"
                            android:text="@string/main_no_profiles_subtitle"
                            android:textAppearance="@style/TextAppearance.App.BodyMedium"
                            android:textColor="?attr/colorMainDashboardText" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/AppButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:onClick="@{() -> self.request(Request.OpenNewProfile)}"
                            android:text="@string/main_add_subscription"
                            app:icon="@drawable/ic_neon_toolbar_add"
                            app:iconGravity="textStart"
                            app:iconPadding="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/main_bottom_nav_card"
            style="@style/AppCard.BottomNav"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="bottom"
            android:layout_marginHorizontal="@dimen/main_bottom_nav_horizontal_margin"
            android:layout_marginBottom="@dimen/main_bottom_nav_bottom_margin"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
            app:cardCornerRadius="@dimen/main_bottom_nav_corner_radius"
            app:cardElevation="@dimen/main_bottom_nav_elevation"
            app:cardUseCompatPadding="false"
            app:rippleColor="?attr/colorControlHighlight"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:baselineAligned="false"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingVertical="3dp">

                <LinearLayout
                    android:id="@+id/main_nav_profiles"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/nav_subscriptions"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_baseline_subscriptions"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/nav_subscriptions"
                        android:textAppearance="@style/TextAppearance.App.BottomNavigation"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/main_nav_logs"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/logs"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_outline_article"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/logs"
                        android:textAppearance="@style/TextAppearance.App.BottomNavigation"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/main_nav_routing"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/nav_routing"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_baseline_route"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/nav_routing"
                        android:textAppearance="@style/TextAppearance.App.BottomNavigation"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/main_nav_connections"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/nav_connections"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_baseline_swap_horiz"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/nav_connections"
                        android:textAppearance="@style/TextAppearance.App.BottomNavigation"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/main_add_profile_fab"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="66dp"
            android:contentDescription="@{clashRunning ? @string/shortcut_stop_short : @string/shortcut_start_short}"
            android:onClick="@{() -> self.request(Request.ToggleStatus)}"
            android:src="@{clashRunning ? @drawable/ic_baseline_stop : @drawable/ic_baseline_vpn_lock}"
            app:backgroundTint="?attr/colorPrimaryContainer"
            app:fabCustomSize="48dp"
            app:tint="?attr/colorOnPrimaryContainer" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>

