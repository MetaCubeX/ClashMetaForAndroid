<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="16dp">

    <ImageView
        android:id="@+id/drag_handle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="@string/rules_hub_drag_handle"
        android:padding="6dp"
        android:src="@drawable/ic_baseline_menu"
        app:tint="?attr/colorOnSurfaceVariant" />

    <TextView
        android:id="@+id/rule_index"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.App.LabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/rule_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.App.BodyMedium"
            android:textColor="?attr/colorOnSurface"
            tools:text="DOMAIN,example.com" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/policy_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textAppearance="@style/TextAppearance.App.LabelSmall"
                android:textStyle="bold"
                tools:background="@drawable/bg_m3_policy_chip_primary"
                tools:text="PROXY" />

            <TextView
                android:id="@+id/source_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_m3_status_chip_neutral"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="@string/effective_rules_source_manual"
                android:textAppearance="@style/TextAppearance.App.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <TextView
            android:id="@+id/target_missing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/rules_hub_target_missing"
            android:textAppearance="@style/TextAppearance.App.LabelSmall"
            android:textColor="?attr/colorError"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/rule_enabled_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@+id/btn_edit"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/edit"
        android:padding="6dp"
        android:src="@drawable/ic_baseline_edit"
        app:tint="?attr/colorOnSurfaceVariant" />
</LinearLayout>
