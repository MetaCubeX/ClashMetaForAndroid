<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="profile"
            type="com.github.kr328.clash.service.model.Profile" />
        <variable
            name="clicked"
            type="android.view.View.OnClickListener" />
        <import type="android.view.View" />
        <import type="com.github.kr328.clash.design.util.I18nKt" />
    </data>

    <!-- One RecyclerView row: profile strip + optional proxy block (siblings, no overlap) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/item_header_margin"
        android:layout_marginBottom="@dimen/profile_item_spacing"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profile_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            app:strokeColor="?attr/colorPrimary">

            <LinearLayout
                android:id="@+id/root_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/profileCardBackground"
                android:baselineAligned="false"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="@dimen/profile_header_strip_height"
                android:onClick="@{clicked}"
                android:orientation="horizontal"
                android:paddingVertical="6dp"
                android:paddingStart="10dp"
                android:paddingEnd="8dp">

                <View
                    android:id="@+id/active_strip"
                    android:layout_width="3dp"
                    android:layout_height="@dimen/profile_header_strip_height"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="10dp"
                    android:background="?attr/colorPrimary"
                    android:visibility="@{profile.active ? View.VISIBLE : View.INVISIBLE}" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="@{profile.name}"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        tools:text="Profile" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.88"
                        android:text="@{profile.pending ? @string/format_type_unsaved(I18nKt.toString(profile.type, context)) : I18nKt.toString(profile.type, context)}"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="URL" />

                    <TextView
                        android:id="@+id/usage_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="1.2 GiB / ∞"
                        tools:visibility="visible" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='@{profile.expire>0 ? I18nKt.toDateStr(profile.expire):""}'
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="@{profile.expire==0 ? View.GONE : View.VISIBLE}" />

                    <ProgressBar
                        android:id="@+id/usage_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:max="1000"
                        android:visibility="gone"
                        tools:progress="400"
                        tools:visibility="visible" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/force_update_slot"
                    android:layout_width="@dimen/profile_action_slot"
                    android:layout_height="@dimen/profile_action_slot"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="2dp">

                    <ImageView
                        android:id="@+id/force_update_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:contentDescription="@string/profile_force_update"
                        android:focusable="true"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_baseline_sync"
                        android:visibility="gone"
                        app:tint="?attr/colorControlNormal" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/ping_slot"
                    android:layout_width="@dimen/profile_action_slot"
                    android:layout_height="@dimen/profile_action_slot"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="2dp">

                    <ImageView
                        android:id="@+id/ping_all_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:contentDescription="@string/profile_ping_all"
                        android:focusable="true"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_speedometer_ping"
                        android:visibility="gone"
                        app:tint="?attr/colorPrimary" />

                    <ProgressBar
                        android:id="@+id/ping_progress"
                        style="?android:attr/progressBarStyle"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="?attr/colorPrimary"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/chevron_slot"
                    android:layout_width="@dimen/profile_action_slot"
                    android:layout_height="@dimen/profile_action_slot"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="2dp">

                    <ImageView
                        android:id="@+id/chevron_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:contentDescription="@string/profile_expand_proxies"
                        android:focusable="true"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_baseline_expand_more"
                        android:visibility="gone"
                        app:tint="?attr/colorControlNormal" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/menu_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="@dimen/item_tailing_component_size"
                        android:layout_height="@dimen/item_tailing_component_size"
                        android:layout_margin="6dp"
                        android:contentDescription="@string/more"
                        android:src="@drawable/ic_baseline_more_vert"
                        app:tint="?attr/colorControlNormal" />
                </FrameLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Separate block: NOT inside profile card -->
        <LinearLayout
            android:id="@+id/proxy_expand_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/profile_proxy_block_spacing"
            android:background="?attr/profileProxyBlockBackground"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="6dp"
                android:text="@string/profile_proxy_group"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <Spinner
                android:id="@+id/proxy_group_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="44dp" />

            <LinearLayout
                android:id="@+id/proxy_nodes_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>
    </LinearLayout>
</layout>
