<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_m3_segment_container"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/group_block_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="52dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/group_block_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.App.LabelLarge"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    tools:text="Proxies" />

                <TextView
                    android:id="@+id/group_block_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_m3_status_chip_neutral"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"
                    android:textAppearance="@style/TextAppearance.App.LabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone"
                    tools:text="Selector"
                    tools:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/group_block_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"
                tools:text="Germany 1"
                tools:visibility="visible" />
        </LinearLayout>

        <TextView
            android:id="@+id/group_block_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_segment_count"
            android:gravity="center"
            android:minWidth="20dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="12" />

        <FrameLayout
            android:id="@+id/group_block_ping_slot"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp">

            <ImageView
                android:id="@+id/group_block_ping"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/profile_ping_all"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_speedometer_ping"
                app:tint="?attr/colorPrimary" />

            <ProgressBar
                android:id="@+id/group_block_ping_progress"
                style="?android:attr/progressBarStyle"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:indeterminateTint="?attr/colorPrimary"
                android:visibility="gone" />
        </FrameLayout>

        <ImageView
            android:id="@+id/group_block_chevron"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="2dp"
            android:contentDescription="@string/profile_expand_proxies"
            android:padding="3dp"
            android:rotation="-90"
            android:scaleType="centerInside"
            android:src="@drawable/ic_baseline_expand_more"
            app:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/group_block_nodes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone" />
</LinearLayout>
