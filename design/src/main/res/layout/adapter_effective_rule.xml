<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:paddingHorizontal="4dp">

    <TextView
        android:id="@+id/rule_index"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:alpha="0.7"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
        tools:text="1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rule_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:textSize="12sp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            tools:text="RULE-SET,MyRules,PROXY" />

        <TextView
            android:id="@+id/rule_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.75"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            tools:text="MANUAL" />
    </LinearLayout>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/rule_enabled_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true" />

    <ImageButton
        android:id="@+id/rule_more"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/rule_snippet_overflow_cd"
        android:src="@drawable/ic_baseline_more_vert" />
</LinearLayout>
