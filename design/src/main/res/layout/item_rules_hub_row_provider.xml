<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="16dp">

    <TextView
        android:id="@+id/rule_index"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:textAppearance="@style/TextAppearance.App.LabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/rule_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.App.BodyMedium"
            android:textColor="?attr/colorOnSurface"
            tools:text="RULE-SET,ads" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/policy_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textAppearance="@style/TextAppearance.App.LabelSmall"
                android:textStyle="bold"
                tools:background="@drawable/bg_m3_policy_chip_reject"
                tools:text="REJECT" />

            <TextView
                android:id="@+id/rule_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_m3_status_chip_neutral"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textAppearance="@style/TextAppearance.App.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Provider · ads" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/rule_enabled_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@+id/btn_restore"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/rule_action_restore"
        android:padding="6dp"
        android:src="@drawable/ic_baseline_restore"
        android:visibility="gone"
        app:tint="?attr/colorPrimary"
        tools:visibility="visible" />
</LinearLayout>
