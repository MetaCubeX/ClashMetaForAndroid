<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="fullScreenDialogTheme" format="reference" />

    <attr name="colorBackground" format="color" />
    <attr name="colorOnBackground" format="color" />

    <attr name="colorClashStopped" format="color" />
    <attr name="colorControlDisabled" format="color" />
    <attr name="colorLogo" format="color" />

    <!-- YAML config viewer syntax highlighting (resolves per AppThemeLight / AppThemeDark) -->
    <attr name="yamlKey" format="color" />
    <attr name="yamlString" format="color" />
    <attr name="yamlNumber" format="color" />
    <attr name="yamlKeyword" format="color" />
    <attr name="yamlComment" format="color" />
    <attr name="yamlPunctuation" format="color" />
    <attr name="yamlPlain" format="color" />

    <!-- Main dashboard (home): resolves per AppThemeLight / AppThemeDark -->
    <attr name="mainDashboardBackground" format="reference" />
    <attr name="colorMainDashboardText" format="color" />
    <attr name="colorMainModeChipLabel" format="color" />
    <attr name="colorMainCardGlass" format="color" />
    <attr name="colorMainBottomNavGlass" format="color" />
    <attr name="colorMainGlassStroke" format="color" />
    <!-- Profile list row + expanded proxy panel (home) -->
    <attr name="profileCardBackground" format="reference" />
    <attr name="profileProxyBlockBackground" format="reference" />

    <attr name="enabled" format="boolean" />
    <attr name="text" format="string" />
    <attr name="subtext" format="string" />
    <attr name="icon" format="reference" />
    <attr name="color" format="color" />
    <attr name="placeholder" format="string" />
    <attr name="title" format="string" />

    <declare-styleable name="LargeActionCard">
        <attr name="text" />
        <attr name="subtext" />
        <attr name="icon" />
    </declare-styleable>

    <declare-styleable name="LargeActionLabel">
        <attr name="text" />
        <attr name="subtext" />
        <attr name="icon" />
    </declare-styleable>

    <declare-styleable name="ActionLabel">
        <attr name="enabled" />
        <attr name="text" />
        <attr name="subtext" />
        <attr name="icon" />
    </declare-styleable>

    <declare-styleable name="ActionTextField">
        <attr name="enabled" />
        <attr name="icon" />
        <attr name="title" />
        <attr name="text" />
        <attr name="placeholder" />
    </declare-styleable>

    <declare-styleable name="Clickable">
        <attr name="android:focusable" />
        <attr name="android:clickable" />
        <attr name="android:background" />
        <attr name="android:foreground" />
    </declare-styleable>

    <declare-styleable name="BoundedNestedScrollView">
        <attr name="maxHeight" format="dimension" />
    </declare-styleable>
</resources>