<?xml version="1.0" encoding="utf-8"?>
<!-- Top-weighted radial highlight so the connect button reads as a lit 3D orb, not a flat disc.
     White so it works over any dynamic accent (and the neutral idle fill). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:centerX="0.5"
        android:centerY="0.30"
        android:endColor="#00FFFFFF"
        android:gradientRadius="82dp"
        android:startColor="#33FFFFFF"
        android:type="radial" />
</shape>
